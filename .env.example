# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (https://neon.tech)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — from: stripe listen --forward-to .../api/webhooks/stripe
# Or from Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Transactional email via https://resend.com (free tier: 3,000 emails/month)
# 1. Sign up at resend.com
# 2. Verify your domain (aibridgesolutions.co.uk)
# 3. Create an API key and paste it here
RESEND_API_KEY=re_...
SMTP_FROM=kevin@aibridgesolutions.co.uk

# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed app — used in QR code URLs and email links
APP_BASE_URL=https://your-site.vercel.app

# Random secret used to protect admin/check-in pages (keep this private)
ADMIN_TOKEN=change-me-to-a-long-random-string

# Optional — defaults to 2026-09-02 if omitted
NEXT_PUBLIC_EVENT_DATE=2026-09-02
